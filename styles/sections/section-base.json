{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"blockTypes": ["core/group", "core/columns", "core/column"],
	"slug": "section-base",
	"title": "[Base]",
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast-3"
		},
		"elements": {
			"heading":{
				"color": {
					"text": "var:preset|color|contrast-2"
				}
			}
		},
		"blocks":{
			"core/accordion-item": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--base-5)",
						"style": "solid",
						"width": "1px"
					}
				}
			}
		}
	}
}
