{
	"name": "upa25",
	"version": "0.3.0",
	"main": "index.js",
	"scripts": {
		"start": "PROLOOKS_BS_PROXY=http://uniquepoleart.local wp-scripts start --config webpack.dev.js",
		"build": "wp-scripts build --config webpack.prod.js",
		"lint:css": "wp-scripts lint-style 'src/**/*.scss'",
		"lint:css:fix": "wp-scripts lint-style 'src/**/*.scss' --fix",
		"lint:js": "wp-scripts lint-js 'src/**/*.{js,jsx,json,ts,tsx}'",
		"format": "wp-scripts format 'src/**/*.{js,jsx,json,ts,tsx,css,scss}' '!src/fonts/**'",
		"format:reorder": "prettier --write --plugin=prettier-plugin-css-order 'src/**/*.{css,scss}'",
		"zip": "wp-scripts plugin-zip",
		"packages-update": "wp-scripts packages-update"
	},
	"files": [
		"/*",
		"!/src",
		"!.vscode",
		"!.editorconfig",
		"!.gitignore",
		"!package.json",
		"!webpack.*.js",
		"!**/.webpack-cache/**"
	],
	"author": "hanneslsm",
	"license": "GPL-2.0",
	"description": "",
	"prettier": "@wordpress/prettier-config",
	"devDependencies": {
		"@wordpress/scripts": "^31.3.0",
		"browser-sync": "^3.0.4",
		"browser-sync-webpack-plugin": "^2.4.0",
		"copy-webpack-plugin": "^12.0.2",
		"sharp": "^0.33.5",
		"webpack-remove-empty-scripts": "^1.0.4",
		 "prettier-plugin-css-order": "^2.1.0"
	}
}
