{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"blockTypes": [ "core/group", "core/columns", "core/column" ],
	"slug": "section-brand-4",
	"title": "[Brand-4]",
	"styles": {
		"color": {
			"background": "var:preset|color|brand-4",
			"text": "var:preset|color|contrast-3"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var:preset|color|contrast"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|brand"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|brand-2"
					},
					"typography": {
						"textDecoration": "underline"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"color": {
					"background": "var:preset|color|brand-3",
					"text": "var:preset|color|base"
				}
			},
			"core/separator": {
				"color": {
					"text": "var:preset|color|brand-3"
				}
			},
			"core/accordion-item": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--brand-3)",
						"style": "solid",
						"width": "1px"
					}
				}
			}
		}
	}
}
